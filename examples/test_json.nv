// UFCS demo — p.to_json() with print
@import("std/compile/json")
@import("std/test")

struct Point {
    x: Float,
    y: Float,
}

@json(Point)

func main() -> Int {
    let p = Point { x: 3.0, y: 2.0 };

    // UFCS: p.to_json() calls to_json(p)
    let json = p.to_json();
    assert_eq("to_json", json, "{\"x\":3.000000,\"y\":2.000000}");

    return 0
}

@import("std/compile/debug")
@import("std/test")

struct Point { x: Float, y: Float }
struct Rect { top_left: Point, bottom_right: Point }

@debug(Point)
@debug(Rect)

func main() -> Int {
    let r = Rect { top_left: Point { x: 0.0, y: 0.0 }, bottom_right: Point { x: 10.0, y: 10.0 } };
    r.debug();  // nested structs indent one level per depth
    assert_true("nested field access", r.bottom_right.x == 10.0);
    return 0
}

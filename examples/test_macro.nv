// Test macro expansion
@import("std/test")
macro make_adder(name, amount) {
    quote {
        func $name(x: Int) -> Int {
            return x + $amount
        }
    }
}

@make_adder(add_five, 5)
@make_adder(add_ten, 10)

func main() -> Int {
    let a = add_five(10);
    let b = add_ten(10);
    assert_eq("add_five(10)", a, 15);
    assert_eq("add_ten(10)", b, 20);
    return 0
}

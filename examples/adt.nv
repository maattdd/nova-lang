// Algebraic Data Types & Pattern Matching in Nova

enum Option[T] {
    case some(T),
    case none
}

// Pattern matching on ADTs
func get_or_default(opt: Option[Int], default: Int) -> Int {
    match opt {
        case .some(val) => val
        case .none => default
    }
}

func main() -> Int {
    // In real code, you'd construct ADT values.
    // For now, this demonstrates pattern matching compilation.
    let x: Int = 42;
    return x
}

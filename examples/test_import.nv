// Demonstrates the @import module system with renaming

// Import everything (square, cube)
@import("std.math")

// Import with rename: square becomes sq
@import("std.math", square = sq)

// Import just one item
@import("std.math", cube)

@import("std/test")

func main() -> Int {
    let a = square(3);   // 9 — imported from std.math
    let b = sq(4);       // 16 — renamed import
    let c = cube(2);     // 8 — explicitly imported

    assert_eq("square(3)", a, 9);
    assert_eq("sq(4)", b, 16);
    assert_eq("cube(2)", c, 8);
    return 0
}
